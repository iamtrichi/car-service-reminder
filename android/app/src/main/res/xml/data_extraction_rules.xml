<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules for Android 12+ (API 31+).

  These rules work alongside Google Play Auto Backup and
  device-to-device transfer. They specify which data should
  be backed up / transferred.
-->
<data-extraction-rules>
  <cloud-backup>
    <!-- Include all SharedPreferences (Capacitor Preferences) -->
    <include domain="sharedpref" path="."/>
    <!-- Include internal files -->
    <include domain="file" path="."/>
    <!-- Include databases -->
    <include domain="database" path="."/>
  </cloud-backup>

  <device-transfer>
    <include domain="sharedpref" path="."/>
    <include domain="file" path="."/>
    <include domain="database" path="."/>
  </device-transfer>
</data-extraction-rules>